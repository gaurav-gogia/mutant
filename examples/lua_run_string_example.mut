putln("=== lua_run_string example ===");

let result = lua_run_string("return 'hello-from-lua-string' .. ':' .. mutant.version()");

if (result["ok"]) {
    putln("lua_run_string ok");
    putf("result: ", result["result"]);
    putln();
} else {
    putln("lua_run_string failed: ", result["error"]);
};