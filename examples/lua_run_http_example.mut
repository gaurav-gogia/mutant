putln("=== lua_run_http example ===");
putln("requires capability: network");
putln("set URL to an endpoint that returns plain Lua source code");

let url = "http://127.0.0.1:8080/lua_patch.lua";
let result = lua_run_http(url);

if (result["ok"]) {
    putln("lua_run_http ok");
    putln("result: ", result["result"]);
} else {
    putln("lua_run_http failed: ", result["error"]);
};