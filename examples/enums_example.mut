enum Color { Red, Blue, Green };

let active = Color.Green;

putln("enum value demo:");
putf("active = ", active);
putln("");

if (active) {
    putln("enum values are truthy in conditionals");
} else {
    putln("this branch should not run");
}

putln("");
active = Color.Red;
putln(active);

if (active == Color.Blue) {
    putln("blue found");
} else {
    putln("this is not blue");
}
